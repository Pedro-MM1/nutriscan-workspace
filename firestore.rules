rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Usuário lê/escreve apenas seus próprios documentos.
    // request.auth != null já cobre usuários anônimos — o Firebase atribui
    // um uid a eles, então request.auth.uid == uid funciona normalmente.
    match /users/{uid}/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }
  }
}
